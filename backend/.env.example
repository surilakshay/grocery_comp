# Anthropic API key
ANTHROPIC_API_KEY=your_api_key_here

# Zepto MCP Server
ZEPTO_MCP_URL=http://localhost:3001/mcp
ZEPTO_MCP_TOKEN=your_zepto_token

# Instamart MCP Server
INSTAMART_MCP_URL=http://localhost:3002/mcp
INSTAMART_MCP_TOKEN=your_instamart_token

# Set to "true" to use mock data instead of real MCP calls (for local dev)
USE_MOCK_PROVIDERS=false

# Delivery fee assumptions for optimization (in INR)
ZEPTO_DELIVERY_FEE=25
INSTAMART_DELIVERY_FEE=30
